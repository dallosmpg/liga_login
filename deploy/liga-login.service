[Unit]
Description=Liga Login Web App
After=network.target

[Service]
Type=simple
WorkingDirectory=/srv/liga_login
Environment=NODE_ENV=production
EnvironmentFile=/srv/liga_login/.env
ExecStart=/usr/bin/node /srv/liga_login/server.js
Restart=always
RestartSec=3
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
